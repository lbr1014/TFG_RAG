# Archivo de entorno para Docker Compose.

# Compose
SHARED_NETWORK_NAME=shared_net
SHARED_NETWORK_DRIVER=bridge

# GPU
NVIDIA_RUNTIME=nvidia
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Servicio Ollama para LLM local
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_CONTAINER_NAME=flask_ollama
OLLAMA_BIND_ADDRESS=0.0.0.0:11435
OLLAMA_HOST_PORT=11435
OLLAMA_CONTAINER_PORT=11435
OLLAMA_CONTAINER_DATA_DIR=/root/.ollama
OLLAMA_VOLUME_NAME=ollama_data
OLLAMA_RESTART_POLICY=unless-stopped
OLLAMA_HEALTHCHECK_TEST=timeout 10 bash -c 'cat < /dev/null > /dev/tcp/localhost/11435' || exit 1
OLLAMA_HEALTHCHECK_INTERVAL=30s
OLLAMA_HEALTHCHECK_TIMEOUT=15s
OLLAMA_HEALTHCHECK_RETRIES=5
OLLAMA_HEALTHCHECK_START_PERIOD=30s
OLLAMA_DEPENDS_ON_CONDITION=service_healthy

# Servicio Qdrant para base de datos vectorial
QDRANT_IMAGE=qdrant/qdrant:latest
QDRANT_CONTAINER_NAME=flask_qdrant
QDRANT_HOST_PORT=6333
QDRANT_CONTAINER_PORT=6333
QDRANT_CONTAINER_DATA_DIR=/qdrant/storage
QDRANT_VOLUME_NAME=qdrant_data
QDRANT_API_KEY=
QDRANT_RESTART_POLICY=unless-stopped
QDRANT_HEALTHCHECK_TEST=timeout 10 bash -c 'cat < /dev/null > /dev/tcp/localhost/6333' || exit 1
QDRANT_HEALTHCHECK_INTERVAL=30s
QDRANT_HEALTHCHECK_TIMEOUT=10s
QDRANT_HEALTHCHECK_RETRIES=3
QDRANT_HEALTHCHECK_START_PERIOD=10s
QDRANT_DEPENDS_ON_CONDITION=service_healthy

# Servicio ARES runner
ARES_BUILD_CONTEXT=.
ARES_DOCKERFILE=evalaucion_rag/Dockerfile
ARES_CONTAINER_NAME=flask_evalaucion_rag
ARES_RESTART_POLICY=no

# Volumenes y rutas montadas
HOST_DOCUMENTOS_DIR=./documentos
CONTAINER_DOCUMENTOS_DIR=/data/documentos
DOCUMENTOS_VOLUME_MODE=ro
HOST_OUTPUTS_DIR=./outputs
CONTAINER_OUTPUTS_DIR=/app/outputs
HF_CACHE_CONTAINER_DIR=/root/.cache/huggingface
HF_CACHE_VOLUME_NAME=hf_cache

# Modelos
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
RAGAS_JUDGE_MODEL=gemma3:4b
RAGAS_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAGAS_EMBEDDINGS_DEVICE=cuda

# Endpoints y rutas internas
ARES_OLLAMA_BASE_URL=http://flask_ollama:11435
QDRANT_URL=http://flask_qdrant:6333
DOCS_DIR=/data/documentos
RAGAS_QUESTIONS_PATH=/app/questions_auto_ARES.json
RAGAS_RESULTS_PATH=/app/outputs/ragas_results.json
RAGAS_ROW_RESULTS_PATH=/app/outputs/ragas_results_rows.json
CONFIGURACION_PATH=/app/outputs/configuracion.json
ARES_DATASET_JSON_PATH=/app/ares_dataset.json
ARES_DATASET_TSV_PATH=/app/dataset_auto_ARES.tsv
ARES_QUESTIONS_PATH=/app/questions_auto_ARES.json

# Generacion de preguntas/dataset
ARES_NUM_QUESTIONS=10
ARES_MAX_SOURCE_CHUNKS=200
ARES_QAS_PER_CHUNK=2
ARES_FORCE_REGENERATE=0

# Evaluacion RAGAS
RAGAS_METRICS=faithfulness,answer_relevancy,answer_correctness,context_precision,context_recall,context_relevancy
RAGAS_K_CONTEXTS=3
RAGAS_REQUEST_TIMEOUT=1800
RAGAS_RAISE_EXCEPTIONS=1

# Pesos de combinacion final
FINAL_RAGAS_WEIGHT=0.7
FINAL_FALLBACK_WEIGHT=0.3
