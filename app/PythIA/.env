# Flask
FLASK_APP=run.py
# Valor real definido en secret.env.
FLASK_SESSION_SIGNER=

# Postgres
POSTGRES_USER=postgres
POSTGRES_DB=mydatabase
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Dirección de los pliegos
DOCS_DIR=/data/pliegos

# Cache
HF_HOME=/data/hf

QDRANT_COLLECTION=chunks

